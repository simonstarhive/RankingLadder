@{
    Layout = "_Layout";
}

<div class="min-h-screen flex items-center justify-center bg-blue-50">
    <div class="bg-white p-8 rounded-2xl shadow-lg w-full max-w-md">

        <!-- LOGO + TITLE -->
        <div class="text-center mb-6">
            <h1 class="text-2xl font-bold text-gray-800">
                UCF Club Tennis
            </h1>
        </div>

        @if (ViewBag.Error != null) {
            <div class="bg-red-100 text-red-700 p-3 rounded mb-4">
                 @ViewBag.Error
            </div>
        }

        <!-- FORM -->
        <form asp-controller="Auth" asp-action="Login" method="post">

            <!-- EMAIL -->
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700">email</label>
                <input name="mail" type="email"
                       class="w-full mt-1 p-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400" />
            </div>

            <!-- PASSWORD -->
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700">password</label>
                <input name="password" type="password"
                       class="w-full mt-1 p-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400" />
            </div>

            <!-- LOGIN BUTTON -->
            <button type="submit"
                    class="w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 rounded-lg">
                Log In
            </button>

        </form>

        <!-- REGISTER -->
        <button onclick="location.href='/Auth/Signup'"
                class="w-full bg-gray-200 hover:bg-gray-300 text-black font-semibold py-2 rounded-lg mt-3">
            Register
        </button>

    </div>
</div>